{
  "extends": "@cloudbeaver/tsconfig/tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "composite": true
  },
  "references": [
    {
      "path": "../core-browser"
    },
    {
      "path": "../core-cli"
    },
    {
      "path": "../plugin-sso"
    },
    {
      "path": "../plugin-tailwindcss-theme"
    },
    {
      "path": "../product-base"
    },
    {
      "path": "../product-default-impl"
    }
  ],
  "include": [
    "__custom_mocks__/**/*",
    "src/**/*",
    "src/**/*.json",
    "src/**/*.css"
  ],
  "exclude": [
    "**/node_modules",
    "dist/**/*",
    "lib/**/*"
  ]
}
